rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function logado() {
      return request.auth != null;
    }

    function ehAdmin() {
      return logado()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function travaMillis() {
      return get(/databases/$(database)/documents/config/global).data.travaGruposTimestamp;
    }

    function configExiste() {
      return exists(/databases/$(database)/documents/config/global);
    }

    // Antes da trava se: nao ha config ainda, ou campo ausente, ou agora < trava.
    // Aceita int e float pois JS envia number que pode vir como float no Firestore.
    function antesDaTrava() {
      return !configExiste()
        || !('travaGruposTimestamp' in get(/databases/$(database)/documents/config/global).data)
        || request.time.toMillis() < get(/databases/$(database)/documents/config/global).data.travaGruposTimestamp;
    }

    // "Portao" do mata-mata: libera a ESCRITA de palpites ate o inicio da final
    // (19/07/2026 16:00 UTC = 13:00 BRT). A trava fina por jogo (cada confronto
    // fecha 23:59 BRT da vespera, fase a fase) e feita na APLICACAO — a regra so
    // garante que ninguem grave palpite depois que a Copa acabou. O documento de
    // palpites e unico (bets/{uid}), entao a regra nao consegue validar jogo a
    // jogo; por isso o controle fino fica na tela.
    function mataMataLiberado() {
      return request.time.toMillis() < 1784516399000; // 19/07/2026 23:59:59 BRT (fim do dia da final)
    }

    // Usuarios: cada um cria/edita o proprio doc.
    // isAdmin so pode ser true se o email esta na lista de admins definida no codigo.
    // A lista de emails admin e verificada no servidor (db.js) — a regra apenas
    // impede que um usuario comum se promova: nao pode mudar isAdmin de false para true.
    match /users/{uid} {
      allow read: if logado();
      allow create: if logado()
        && request.auth.uid == uid;
      allow update: if logado()
        && request.auth.uid == uid
        && (
          resource.data.isAdmin == true          // ja era admin, pode atualizar
          || request.resource.data.isAdmin == false  // nao era admin, continua nao sendo
        );
      // Admin pode remover outros usuarios (usado para resetar o bolao).
      allow delete: if ehAdmin();
    }

    // Jogos: leitura para logados, escrita so admin.
    match /matches/{id} {
      allow read: if logado();
      allow write: if ehAdmin();
    }

    // Palpites: cada um escreve no proprio doc. Permitido enquanto a fase de
    // grupos nao travou (palpites de grupos) OU enquanto o mata-mata esta em
    // andamento (palpites de KO). A trava fina por jogo e' feita na aplicacao.
    // Admin pode apagar qualquer doc (usado para zerar a base entre testes).
    match /bets/{uid} {
      allow read: if logado();
      allow write: if logado()
        && request.auth.uid == uid
        && (antesDaTrava() || mataMataLiberado());
      allow delete: if ehAdmin();
    }

    // Resultados oficiais e gabarito: leitura para logados, escrita so admin.
    match /results/{id} {
      allow read: if logado();
      allow write: if ehAdmin();
    }

    // Config global (data de trava): leitura para logados, escrita so admin.
    match /config/{id} {
      allow read: if logado();
      allow write: if ehAdmin();
    }
  }
}
