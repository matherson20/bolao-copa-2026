# Copie este arquivo para ".env" e preencha com os valores do seu projeto Firebase.
# (Firebase Console > Configuracoes do projeto > Seus apps > App da Web > SDK setup and configuration)
# Estas chaves sao PUBLICAS por design. A seguranca vem das regras do Firestore (firestore.rules).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
